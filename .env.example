# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control — it is already in .gitignore.

# ---------------------------------------------------------------------------
# Anthropic API key (required)
# Get yours at: https://console.anthropic.com/settings/keys
# The agent uses claude-haiku for data calls and claude-sonnet for decisions.
# Opus is never used.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---------------------------------------------------------------------------
# Robinhood MCP token (required)
# Run `python setup_auth.py` once to generate this automatically.
# It is the OAuth access token for your Robinhood Agentic account.
# ---------------------------------------------------------------------------
ROBINHOOD_MCP_TOKEN=your_robinhood_mcp_token_here

# ---------------------------------------------------------------------------
# Robinhood OAuth client ID (only needed when running setup_auth.py)
# Check Robinhood's agentic trading docs for your client_id.
# ---------------------------------------------------------------------------
ROBINHOOD_CLIENT_ID=your_robinhood_client_id_here

# ---------------------------------------------------------------------------
# Twilio SMS (optional but strongly recommended for live trading)
# Without these, approvals fall back to stdin prompts.
#
# Sign up at https://www.twilio.com/try-twilio (free trial available)
# TWILIO_FROM  = your Twilio phone number, e.g. +15551234567
# YOUR_PHONE_NUMBER = your personal cell phone number, e.g. +15559876543
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM=+15551234567
YOUR_PHONE_NUMBER=+15559876543

# ---------------------------------------------------------------------------
# Optional: override log level (DEBUG, INFO, WARNING, ERROR)
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
