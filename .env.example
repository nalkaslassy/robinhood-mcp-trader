# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control — it is already in .gitignore.

# ---------------------------------------------------------------------------
# Anthropic API key (required)
# Get yours at: https://console.anthropic.com/settings/keys
# Used only for the weekly watchlist review (Claude Sonnet, once per week).
# Daily research uses yfinance — free, no API cost.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---------------------------------------------------------------------------
# Robinhood MCP token (required for order placement)
# Run Claude Code once and connect the Robinhood MCP server via /mcp.
# The token is auto-refreshed by Claude Code and read from ~/.claude/.credentials.json.
# Only used when a trade is actually approved and placed.
# ---------------------------------------------------------------------------
ROBINHOOD_MCP_TOKEN=your_robinhood_mcp_token_here

# ---------------------------------------------------------------------------
# WhatsApp notifications via CallMeBot (optional but recommended)
# Free service — no carrier registration, no monthly fees.
#
# Setup (2 minutes, one-time):
#   1. Add +34 644 41 14 19 to your WhatsApp contacts
#   2. Send it: "I allow callmebot to send me messages"
#   3. It replies with your API key — paste it below
#
# Without this, trade proposals appear in the terminal (run.bat window).
# ---------------------------------------------------------------------------
YOUR_PHONE_NUMBER=+15559876543
CALLMEBOT_API_KEY=your_callmebot_api_key_here

# ---------------------------------------------------------------------------
# Optional: override log level (DEBUG, INFO, WARNING, ERROR)
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
