# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control — it is already in .gitignore.

# ---------------------------------------------------------------------------
# Anthropic API key (required)
# Get yours at: https://console.anthropic.com/settings/keys
# Used only for the weekly watchlist review (Claude Sonnet, once per week).
# Daily research uses yfinance — free, no API cost.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---------------------------------------------------------------------------
# Robinhood MCP token (required for order placement)
# Connect the Robinhood MCP server in Claude Code via /mcp → robinhood-trading.
# The token is auto-refreshed by Claude Code; the agent reads it automatically
# from ~/.claude/.credentials.json. Only used when a trade fires.
# ---------------------------------------------------------------------------
ROBINHOOD_MCP_TOKEN=your_robinhood_mcp_token_here
ROBINHOOD_CLIENT_ID=LtLiNmbs9owbYfWgBlC68Z2V-claude

# ---------------------------------------------------------------------------
# SMS notifications via Twilio (optional but strongly recommended)
# Requires a paid Twilio phone number (~$1/month + ~$0.008/SMS).
# No session windows — messages arrive reliably every time.
#
# Setup (one-time, ~5 minutes):
#   1. Create an account at twilio.com and add credit
#   2. Buy a phone number: console.twilio.com → Phone Numbers → Buy a number
#   3. Fill in your Twilio SID, token, your Twilio number, and your real number below
#
# Without this, trade proposals print to the terminal and wait for keyboard input.
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM=+15551234567
YOUR_PHONE_NUMBER=+15559876543

# ---------------------------------------------------------------------------
# Optional: override log level (DEBUG, INFO, WARNING, ERROR)
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
